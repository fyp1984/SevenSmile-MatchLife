FROM node:20-bookworm-slim

WORKDIR /runtime

COPY scripts/matchlife-uat/sync-runtime.package.json ./package.json
RUN npm install --omit=dev

COPY scripts/watch-ymq.mjs ./watch-ymq.mjs
COPY scripts/lib/ymq-sync.mjs ./lib/ymq-sync.mjs
COPY scripts/matchlife-uat/run-sync-once.mjs ./run-sync-once.mjs
COPY scripts/matchlife-uat/wechat-oauth-server.mjs ./wechat-oauth-server.mjs
COPY scripts/matchlife-uat/wechat-follower-sync.mjs ./wechat-follower-sync.mjs
