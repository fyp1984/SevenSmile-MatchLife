server {
    listen 80;
    listen [::]:80;
    server_name tools.cheersai.cloud;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name tools.cheersai.cloud;

    ssl_certificate     /etc/nginx/ssl/tools.cheersai.cloud_bundle.pem;
    ssl_certificate_key /etc/nginx/ssl/tools.cheersai.cloud.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    location = /healthz {
        access_log off;
        default_type text/plain;
        return 200 "OK\n";
    }

    location = / {
        root /home/cheersai/apps/tools/current/gateway;
        try_files /index.html =404;
    }

    location /ts/ {
        alias /home/cheersai/apps/tools/current/ts/;
        try_files $uri $uri/ /ts/index.html;
    }

    location /rm/ {
        alias /home/cheersai/apps/tools/current/rm/;
        try_files $uri $uri/ /rm/index.html;
    }

    location /survey/ {
        proxy_pass         http://127.0.0.1:18188/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Prefix /survey;
    }

    # BEGIN MATCHLIFE MANAGED BLOCK
    include /etc/nginx/snippets/7smile-matchlife.tools.cheersai.cloud.locations.conf;
    # END MATCHLIFE MANAGED BLOCK

    access_log /var/log/nginx/tools.cheersai.cloud_access.log;
    error_log  /var/log/nginx/tools.cheersai.cloud_error.log warn;
}
