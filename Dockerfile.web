RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

ARG APP_BASE_PATH=/7smile-matchlife/
ARG VITE_SUPABASE_PROXY_PATH=/7smile-matchlife/supabase
ARG VITE_WECHAT_ACCESS_VERSION=docker-local
ARG VITE_SUPABASE_URL=http://175.178.236.183:8000
ARG VITE_SUPABASE_ANON_KEY
ARG VITE_DATA_SOURCE_PASSWORD=7%K$QJ2pWtgw

ENV APP_BASE_PATH=${APP_BASE_PATH}
ENV VITE_SUPABASE_PROXY_PATH=${VITE_SUPABASE_PROXY_PATH}
ENV VITE_WECHAT_ACCESS_VERSION=${VITE_WECHAT_ACCESS_VERSION}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}
ENV VITE_DATA_SOURCE_PASSWORD=${VITE_DATA_SOURCE_PASSWORD}

RUN APP_BASE_PATH="${APP_BASE_PATH}" \
